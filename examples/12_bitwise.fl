import "std"

# Bitwise operators: & | ^ ~ << >>
# Note: Falcon supports decimal and hex literals (0x...) but not 0b binary.
func main() -> void {
    a: int = 15    # 0x0F = 0000 1111
    b: int = 170   # 0xAA = 1010 1010

    print(a & b)    # AND  = 10
    print(a | b)    # OR   = 175
    print(a ^ b)    # XOR  = 165
    print(~a)       # NOT  = -16 (two's complement)
    print(1 << 4)   # SHL  = 16
    print(128 >> 3) # SHR  = 16
}
