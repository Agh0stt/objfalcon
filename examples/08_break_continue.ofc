import "std"

// break exits a loop early.
// continue skips to the next iteration.
int main() {
    // print 1..4, stop before 5
    int i = 0;
    while (true) {
        i += 1;
        if (i == 5) { break; }
        print(i);
    }

    // print only odd numbers 1..9
    int j = 0;
    while (j < 10) {
        j += 1;
        if (j % 2 == 0) { continue; }
        print(j);
    }
    return 0;
}
